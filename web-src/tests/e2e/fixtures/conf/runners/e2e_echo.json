{
  "name": "E2E Echo",
  "group": "E2E Group",
  "description": "Fixture script for the Playwright e2e suite",
  "script_path": "python3 e2e_echo.py",
  "working_directory": "./web-src/tests/e2e/fixtures/scripts",
  "parameters": [
    {
      "name": "Mode",
      "param": "--mode",
      "type": "list",
      "values": [
        "alpha",
        "beta",
        "gamma"
      ],
      "default": "alpha"
    },
    {
      "name": "Message",
      "param": "--message",
      "required": true
    },
    {
      "name": "ConfFile",
      "param": "--file",
      "type": "server_file",
      "file_dir": ".",
      "file_recursive": true
    }
  ],
  "scheduling": {
    "enabled": true
  }
}